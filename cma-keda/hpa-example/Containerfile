FROM quay.io/fedora/fedora-minimal:45

# Install Python and pip for psutil dependency
RUN microdnf install -y python3.13 python3-pip && \
    pip3 install --no-cache-dir psutil && \
    microdnf clean all && \
    rm -rf /var/cache/yum

COPY --chmod=755 main.py .

EXPOSE 80
USER 1001

CMD ["python3", "main.py"]