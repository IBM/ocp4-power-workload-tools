FROM golang:1.24 AS builder

WORKDIR /src
COPY main.go .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=$(arch) go build -o /out/hpa-example main.go

FROM gcr.io/distroless/static-debian13:latest

COPY --from=builder /out/hpa-example /usr/local/bin/hpa-example

EXPOSE 80
USER 1001

CMD ["/usr/local/bin/hpa-example"]