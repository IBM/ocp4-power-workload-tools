FROM quay.io/fedora/fedora-minimal:45

# Define the user as a build argument
ARG user=fedora

# Install dependencies using microdnf (standard for fedora-minimal)
RUN microdnf -y update \
    && microdnf install -y java-11-openjdk-headless openssl shadow-utils \
    && microdnf clean all

# Create the user and set up environment
RUN useradd $user -g root
ENV container=oci \
    PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

# Set working directory
WORKDIR /home/fedora

# Download the MockServer JAR
ADD --chown=fedora:root https://oss.sonatype.org/service/local/artifact/maven/redirect?r=releases&g=org.mock-server&a=mockserver-netty&c=jar-with-dependencies&e=jar&v=RELEASE /home/fedora/mockserver.jar

# Copy local entrypoint script and other files
COPY --chown=fedora:root . .

# Set permissions as per original image history
RUN chmod ug+rwx . && chmod ug+r mockserver.jar

# Final configuration
USER fedora
EXPOSE 1080/tcp
CMD ["./entrypoint"]