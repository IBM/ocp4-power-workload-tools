FROM quay.io/fedora/fedora-minimal:45

# Define the user as a build argument
ARG user=fedora

# Install dependencies using microdnf (standard for fedora-minimal)
RUN microdnf -y update \
    && microdnf install -y java-25-openjdk-headless.ppc64le openssl shadow-utils \
    && microdnf clean all

# Create the user and set up environment
RUN useradd $user -g root
ENV container=oci \
    PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

# Set working directory
WORKDIR /home/fedora

# Download the MockServer JAR
RUN curl "https://repo.maven.apache.org/maven2/org/mock-server/mockserver-netty/5.9.0/mockserver-netty-5.9.0-jar-with-dependencies.jar" -L -o /home/fedora/mockserver.jar && \
    chown fedora:root /home/fedora/mockserver.jar

# Copy local entrypoint script and other files
COPY --chown=fedora:root . .

# Set permissions as per original image history
RUN chmod ug+rwx . && chmod ug+r mockserver.jar

# Final configuration
USER fedora
EXPOSE 1080/tcp
CMD ["./entrypoint"]